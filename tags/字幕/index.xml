	srcset=&#34;https://www.evine.win/p/%E5%B1%8F%E8%94%BDkodi%E7%9A%84%E5%85%B3%E6%9C%BA%E9%87%8D%E5%90%AF%E6%8C%89%E9%92%AE/pic1_hubfebbcb4d72f4ccfe63d839ca2da7bd7_40874_480x0_resize_box_3.png 480w, https://www.evine.win/p/%E5%B1%8F%E8%94%BDkodi%E7%9A%84%E5%85%B3%E6%9C%BA%E9%87%8D%E5%90%AF%E6%8C%89%E9%92%AE/pic1_hubfebbcb4d72f4ccfe63d839ca2da7bd7_40874_1024x0_resize_box_3.png 1024w&#34;
